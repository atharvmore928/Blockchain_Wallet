":15}}],"sources":{"components/TransactionPool.js":"import React, { Component } from 'react';\r\nimport Transaction from './Transaction';\r\nimport { Link } from 'react-router-dom';\r\n\r\nconst POLL_INTERVAL_MS = 10000; // Capitalized variable convention\r\n\r\nclass TransactionPool extends Component {\r\n    state = { transactionPoolMap: {} };\r\n\r\n    fetchTransactionPoolMap = () => {\r\n        fetch('http://localhost:3000/api/transaction-pool-map')\r\n            .then(response => response.json())\r\n            .then(json => this.setState({ transactionPoolMap: json }));\r\n    }\r\n\r\n    componentDidMount() {\r\n        this.fetchTransactionPoolMap();\r\n\r\n        // Save a reference to the interval on the class instance\r\n        this.fetchPoolInterval = setInterval(\r\n            () => this.fetchTransactionPoolMap(), // Added execution ()\r\n            POLL_INTERVAL_MS                      // Fixed semicolon to comma\r\n        );\r\n    }\r\n\r\n    componentWillUnmount() {\r\n        // Clear the interval to prevent memory leaks when navigating away\r\n        clearInterval(this.fetchPoolInterval);\r\n    }\r\n\r\n    render() {\r\n        return (\r\n            <div className='TransactionPool'>\r\n                <div><Link to='/'>Home</Link></div>\r\n                <h3>Transaction Pool</h3>\r\n                {\r\n                    Object.values(this.state.transactionPoolMap).map(transaction => {\r\n                        return (\r\n                            <div key={transaction.id}>\r\n                                <hr />\r\n                                <Transaction transaction={transaction} />\r\n                            </div>\r\n                        )\r\n                    })\r\n                }\r\n            </div>\r\n        );\r\n    }\r\n}\r\n\r\nexport default TransactionPool;"},"lineCount":null}},"error":null,"hash":"da64a1878d6c6a9a29e7ff822f87d4bb","cacheData":{"env":{}}}