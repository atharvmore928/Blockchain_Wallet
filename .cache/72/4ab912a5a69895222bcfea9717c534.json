e":61,"column":16}},{"generated":{"line":122,"column":33},"source":"components/TransactionPool.js","original":{"line":47,"column":12}},{"generated":{"line":122,"column":34},"source":"components/TransactionPool.js","original":{"line":46,"column":8}},{"generated":{"line":123,"column":0},"source":"components/TransactionPool.js","original":{"line":69,"column":5}},{"name":"Component","generated":{"line":125,"column":2},"source":"components/TransactionPool.js","original":{"line":9,"column":30}},{"name":"TransactionPool","generated":{"line":127,"column":33},"source":"components/TransactionPool.js","original":{"line":72,"column":15}}],"sources":{"components/TransactionPool.js":"import React, { Component } from 'react';\r\nimport { Button } from 'react-bootstrap';\r\nimport Transaction from './Transaction';\r\nimport { Link } from 'react-router-dom';\r\nimport history from '../history';\r\n\r\nconst POLL_INTERVAL_MS = 10000;\r\n\r\nclass TransactionPool extends Component {\r\n    state = { transactionPoolMap: {} };\r\n\r\n    fetchTransactionPoolMap = () => {\r\n        const API_BASE_URL = process.env.REACT_APP_API_URL || document.location.origin;\r\n        fetch(`${API_BASE_URL}/api/transaction-pool-map`)\r\n            .then(response => response.json())\r\n            .then(json => this.setState({ transactionPoolMap: json }));\r\n    }\r\n\r\n    fetchMineTransactions = () => {\r\n        const API_BASE_URL = process.env.REACT_APP_API_URL || document.location.origin;\r\n        fetch(`${API_BASE_URL}/api/mine-transactions`)\r\n            .then(response => {\r\n                if (response.status === 200) {\r\n                    alert('success');\r\n                    history.push('/blocks');\r\n                } else {\r\n                    alert('The mine-transactions request was not successful');\r\n                }\r\n            });\r\n    }\r\n\r\n    componentDidMount() {\r\n        this.fetchTransactionPoolMap();\r\n\r\n        this.fetchPoolInterval = setInterval(\r\n            () => this.fetchTransactionPoolMap(),\r\n            POLL_INTERVAL_MS\r\n        );\r\n    }\r\n\r\n    componentWillUnmount() {\r\n        clearInterval(this.fetchPoolInterval);\r\n    }\r\n\r\n    render() {\r\n        return (\r\n            <div className='TransactionPool'>\r\n                <div><Link to='/'>Home</Link></div>\r\n                <h3>Transaction Pool</h3>\r\n                {\r\n                    Object.values(this.state.transactionPoolMap).map(transaction => {\r\n                        return (\r\n                            <div key={transaction.id}>\r\n                                <hr />\r\n                                <Transaction transaction={transaction} />\r\n                            </div>\r\n                        )\r\n                    })\r\n                }\r\n                <hr />\r\n                <Button\r\n                    bsStyle=\"danger\"\r\n                    onClick={this.fetchMineTransactions}\r\n                >\r\n                    Mine the Transactions\r\n                </Button>\r\n            </div>\r\n        );\r\n    }\r\n}\r\n\r\nexport default TransactionPool;"},"lineCount":null}},"error":null,"hash":"7c9218a0e9969613604e0b730c834b69","cacheData":{"env":{"REACT_APP_API_URL":"http://localhost:3000"}}}