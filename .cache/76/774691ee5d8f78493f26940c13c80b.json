 (typeof res.data === 'string' && res.data.includes('<!DOCTYPE html>')) {\r\n                throw new Error(\"Backend API is not running. The server returned HTML instead of JSON. Ensure the backend is deployed as a Web Service on Render.\");\r\n            } else {\r\n                throw new Error(\"Invalid response from server. Check REACT_APP_API_URL.\");\r\n            }\r\n        } catch (error) {\r\n            console.error('Login Failed:', error);\r\n            this.setState({ error: error.message || 'Failed to authenticate with the server.' });\r\n        }\r\n    };\r\n\r\n    render() {\r\n        return (\r\n            <div className='Login' style={{ textAlign: 'center', marginTop: '50px' }}>\r\n                <h2>Welcome to Blockchain Wallet</h2>\r\n                <p>Please log in to continue.</p>\r\n                <div style={{ display: 'flex', justifyContent: 'center', marginTop: '20px' }}>\r\n                    <GoogleLogin\r\n                        onSuccess={this.handleLoginSuccess}\r\n                        onError={() => {\r\n                            console.log('Login Failed');\r\n                            this.setState({ error: 'Google Login Failed.' });\r\n                        }}\r\n                    />\r\n                </div>\r\n                {this.state.error && <div className='danger-alert'>{this.state.error}</div>}\r\n            </div>\r\n        );\r\n    }\r\n}\r\n\r\nexport default Login;\r\n"},"lineCount":null}},"error":null,"hash":"2f2fb09861ff398b1ed930d0058d5be1","cacheData":{"env":{"REACT_APP_API_URL":"http://localhost:3000"}}}