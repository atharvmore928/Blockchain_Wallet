{
  "name": "cryptochain",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "jest --watchAll",
    "start": "npm run build-client && node index.js",
    "predev": "node scripts/free-port.js 3000",
    "dev": "concurrently \"npm run dev-client\" \"nodemon index.js\"",
    "dev-peer": "cross-env GENERATE_PEER_PORT='true' nodemon index.js",
    "start-redis": "redis-server --daemonize yes",
    "build-client": "npm run clean && parcel build client/src/index.html --out-dir client/dist --public-url ./",
    "dev-client": "npm run clean && cross-env REACT_APP_API_URL=http://localhost:3000 parcel client/src/index.html --out-dir client/dist",
    "clean": "rimraf .cache client/dist"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": ["<rootDir>/setupTests.js"]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "concurrently": "^10.0.3",
    "cross-env": "^5.2.0",
    "jest": "^23.6.0",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^1.19.4",
    "parcel-bundler": "^1.12.3",
    "rimraf": "^6.1.3"
  },
  "dependencies": {
    "@react-oauth/google": "^0.13.5",
    "axios": "^1.18.1",
    "babel-core": "^6.26.3",
    "babel-plugin-transform-class-properties": "^6.24.1",
    "babel-plugin-transform-object-rest-spread": "^6.26.0",
    "babel-preset-env": "^1.7.0",
    "babel-preset-react": "^6.24.1",
    "body-parser": "^1.18.3",
    "bootstrap": "^3.3.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "elliptic": "^6.4.1",
    "express": "^4.16.3",
    "google-auth-library": "^10.9.0",
    "hex-to-binary": "^1.0.1",
    "history": "^4.10.1",
    "jsonwebtoken": "^9.0.3",
    "jwt-decode": "^4.0.0",
    "mongoose": "^9.7.4",
    "pubnub": "^7.0.0",
    "react": "^16.6.0",
    "react-bootstrap": "^0.32.4",
    "react-dom": "^16.6.0",
    "react-router-dom": "^5.3.4",
    "redis": "^2.8.0",
    "request": "^2.88.0"
  }
}
